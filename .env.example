OPENAI_API_KEY=your_openai_key
OPENROUTESERVICE_API_KEY=your_ors_key
GEOCODING_PROVIDER=ors
GOOGLE_GEOCODING_API_KEY=your_google_maps_key
GOOGLE_GEOCODING_LANGUAGE=es
GOOGLE_GEOCODING_REGION=cl
GOOGLE_GEOCODING_COMPONENTS=country:CL

EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=your_email_password

APP_TIMEZONE=America/Santiago
CSV_OUTPUT_PATH=./data
OPENAI_MODEL=gpt-4o-mini
ORS_PROFILE=driving-car
MAX_EXTRACTION_RETRIES=2
EMAIL_SUBJECT_CONTAINS=route planning
EMAIL_UNREAD_SCAN_LIMIT=200
MAP_ENABLED=true
MAP_OUTPUT_PATH=./data/maps

